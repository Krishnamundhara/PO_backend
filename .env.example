# Server
PORT=5000

# SMTP Configuration (Gmail)
# Use Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Optional explicit secure mode. For Gmail:
# - 587 => false (STARTTLS)
# - 465 => true (SSL/TLS)
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Optional SMTP behavior tuning (milliseconds)
SMTP_CONNECTION_TIMEOUT_MS=15000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000

# Optional: set true to verify SMTP before sending (can fail on strict networks)
SMTP_VERIFY=false

# Fixed receiver email address
RECEIVER_EMAIL=fixedemail@gmail.com

# Railway / Linux — use system Chromium installed by nixpacks
# Set both of these in Railway's environment variables
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
